# Secrets
.env
.env.local
.env.*.local

# Extracted store data (populated locally, do not version)
store-data/*.md

# Locally generated images (validate before upload)
generated-images/*.jpg
generated-images/*.jpeg
generated-images/*.png
generated-images/*.webp

# Auto-generated reports (volatile, overwritten on each run)
audit-report.md
visual-audit-report.md
*-report.md

# User data from integrations (CSV, private exports, personal files)
integrations/klaviyo/templates/
integrations/klaviyo/*.csv
integrations/shopify-email/templates-adapted/
integrations/klaviyo/flows.md
integrations/klaviyo/lists.md
integrations/klaviyo/segments.md
integrations/klaviyo/metrics.md
integrations/klaviyo/profiles-summary.md
integrations/klaviyo/klaviyo-summary.md

# User task files (examples are versioned; real tasks are not)
tasks/task-*.md

# GraphQL scratch buffers
.audit-tmp/

# Claude Code local
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Node / IDE
node_modules/
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/
