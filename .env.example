# ============================================================
# .env.example — configuration template for shopify-automation-toolkit
# ------------------------------------------------------------
# 1. Copy this file to .env (at the repo root)
# 2. Fill in your real values
# 3. .env is gitignored and will NEVER be pushed to GitHub
# ============================================================

# ----- Shopify store (required) -----
# Full .myshopify.com domain (without https://)
SHOPIFY_STORE=my-store.myshopify.com

# ----- Brand identity (used in SEO meta tags and alt texts) -----
SHOP_BRAND_NAME=My Store
SHOP_BRAND_DESCRIPTION=A short description of your brand (1-2 sentences).

# Niche vocabulary: keywords (comma-separated) that should appear in
# descriptions and SEO meta tags.
# Leave empty if you don't have a specific niche.
SHOP_BRAND_VOCABULARY=

# HTML shipping block — placed at the beginning of every product
# description by the builders. Keep it simple inline HTML.
SHOP_SHIPPING_HTML=<p>📦 <strong>Fast shipping</strong>. Carefully packed from our warehouse.</p>

# ----- Quality thresholds (tunable) -----
SHOP_DESC_MIN_WORDS=150
SHOP_DESC_TARGET_WORDS=200
SHOP_SEO_TITLE_MIN=30
SHOP_SEO_TITLE_MAX=70
SHOP_SEO_DESC_MIN=50
SHOP_SEO_DESC_MAX=160
SHOP_IMAGE_MIN=3

# ----- Gemini (Google AI Studio) -----
# Get a key from https://aistudio.google.com/app/apikey
# Must start with "AIza" (OAuth tokens "AQ..." do not work).
GEMINI_API_KEY=AIza...

# Gemini models (default values — do not change unless Google releases new ones):
GEMINI_MODEL=gemini-3.1-flash-image-preview
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_VISION_MODEL=gemini-3.1-flash-lite-preview

# ----- Delays & retries (tune if you hit rate limits) -----
SHOP_DELAY_GEMINI_MS=6500
SHOP_DELAY_SHOPIFY_MS=500
SHOP_MAX_RETRIES=3

# ----- Klaviyo (optional — only for integrations/klaviyo/) -----
# Private API key: starts with "pk_..."
KLAVIYO_API_KEY=
