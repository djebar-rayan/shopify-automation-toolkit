# ============================================================
# .env.example — Modèle de configuration pour shopify-automation-toolkit
# ------------------------------------------------------------
# 1. Copier ce fichier en .env (à la racine du repo)
# 2. Remplir avec vos vraies valeurs
# 3. .env est gitignoré et ne sera JAMAIS poussé sur GitHub
# ============================================================

# ----- Boutique Shopify (obligatoire) -----
# Domaine .myshopify.com complet (sans https://)
SHOPIFY_STORE=mon-magasin.myshopify.com

# ----- Identité de marque (utilisée dans les meta SEO et alt texts) -----
SHOP_BRAND_NAME=Ma Boutique
SHOP_BRAND_DESCRIPTION=Une description courte de votre marque (1-2 phrases).

# Vocabulaire de niche : mots-clés (séparés par virgule) qui doivent
# apparaître dans les descriptions et les meta SEO.
# Laisser vide si pas de niche particulière.
SHOP_BRAND_VOCABULARY=

# Bloc HTML livraison — placé au début de chaque description produit
# par les builders. Garder en HTML inline simple.
SHOP_LIVRAISON_HTML=<p>📦 <strong>Livraison rapide</strong>. Expédition soignée depuis notre entrepôt.</p>

# ----- Seuils de qualité (ajustables) -----
SHOP_DESC_MIN_WORDS=150
SHOP_DESC_TARGET_WORDS=200
SHOP_SEO_TITLE_MIN=30
SHOP_SEO_TITLE_MAX=70
SHOP_SEO_DESC_MIN=50
SHOP_SEO_DESC_MAX=160
SHOP_IMAGE_MIN=3

# ----- Gemini (Google AI Studio) -----
# Obtenir une clé sur https://aistudio.google.com/app/apikey
# Doit commencer par "AIza" (les tokens OAuth "AQ..." ne fonctionnent pas).
GEMINI_API_KEY=AIza...

# Modèles Gemini (valeurs par défaut, ne pas modifier sauf changement officiel) :
GEMINI_MODEL=gemini-3.1-flash-image-preview
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_VISION_MODEL=gemini-3.1-flash-lite-preview

# ----- Délais & retries (ajustables si rate limit) -----
SHOP_DELAY_GEMINI_MS=6500
SHOP_DELAY_SHOPIFY_MS=500
SHOP_MAX_RETRIES=3

# ----- Klaviyo (optionnel — uniquement pour integrations/klaviyo/) -----
# Clé Private API : commence par "pk_..."
KLAVIYO_API_KEY=
